{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>tibuntu/renovate-presets",
    "github>tibuntu/renovate-presets:automerge",
    "github>tibuntu/renovate-presets:semanticCommitType(*, build)",
    "github>tibuntu/renovate-presets:githubActionsCommitType"
  ],
  "pre-commit": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": false
  },
  "packageRules": [
    {
      "matchManagers": ["npm"],
      "lockFileMaintenance": {
        "enabled": true,
        "schedule": ["on sunday"]
      }
    },
    {
      "matchFileNames": ["pyproject.toml"],
      "semanticCommitScope": "deps",
      "groupName": "dev dependencies"
    },
    {
      "matchUpdateTypes": ["patch"],
      "groupName": "patch updates",
      "schedule": ["on sunday"]
    },
    {
      "matchPackageNames": ["kubernetes"],
      "groupName": "kubernetes",
      "semanticCommitType": "fix",
      "semanticCommitScope": "deps"
    },
    {
      "matchManagers": ["pre-commit"],
      "groupName": "pre-commit hooks",
      "semanticCommitScope": "deps"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "semanticCommitScope": "deps-actions"
    },
    {
      "matchManagers": ["devcontainer"],
      "groupName": "devcontainer",
      "semanticCommitScope": "deps-devcontainer"
    },
    {
      "matchDepNames": ["ruff", "astral-sh/ruff-pre-commit"],
      "groupName": "ruff",
      "semanticCommitScope": "deps"
    },
    {
      "matchDepNames": ["mypy", "pre-commit/mirrors-mypy"],
      "groupName": "mypy",
      "semanticCommitScope": "deps"
    },
    {
      "matchDepNames": ["bandit", "pycqa/bandit"],
      "groupName": "bandit",
      "semanticCommitScope": "deps"
    },
    {
      "matchDepNames": ["typescript", "@typescript-eslint/eslint-plugin", "@typescript-eslint/parser"],
      "groupName": "typescript",
      "semanticCommitScope": "deps-frontend"
    },
    {
      "description": "Pin TypeScript <7 until typescript-eslint supports it (peer: >=4.8.4 <6.1.0). Remove this rule once @typescript-eslint/eslint-plugin allows TS 7.",
      "matchDepNames": ["typescript"],
      "allowedVersions": "<7"
    },
    {
      "matchFileNames": ["frontend/package.json"],
      "matchDepTypes": ["dependencies"],
      "groupName": "frontend runtime dependencies",
      "semanticCommitType": "fix",
      "semanticCommitScope": "deps-frontend",
      "rangeStrategy": "bump",
      "postUpgradeTasks": {
        "commands": [
          "npm install --prefix frontend",
          "npm run build --prefix frontend"
        ],
        "fileFilters": [
          "frontend/package-lock.json",
          "custom_components/kubernetes/frontend/kubernetes-panel.js"
        ],
        "executionMode": "branch"
      }
    },
    {
      "matchFileNames": ["frontend/package.json"],
      "matchDepTypes": ["devDependencies"],
      "groupName": "frontend dev dependencies",
      "semanticCommitScope": "deps-frontend",
      "rangeStrategy": "bump",
      "postUpgradeTasks": {
        "commands": [
          "npm install --prefix frontend",
          "npm run build --prefix frontend"
        ],
        "fileFilters": [
          "frontend/package-lock.json",
          "custom_components/kubernetes/frontend/kubernetes-panel.js"
        ],
        "executionMode": "branch"
      }
    },
    {
      "matchDepNames": ["pytest-homeassistant-custom-component", "homeassistant", "pytest", "pytest-asyncio"],
      "groupName": "homeassistant",
      "semanticCommitScope": "deps"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track Python package pins in HA manifest.json",
      "managerFilePatterns": [
        "/custom_components/kubernetes/manifest\\.json$/"
      ],
      "matchStrings": [
        "\"(?<depName>[a-zA-Z0-9_-]+)==(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "pypi"
    },
    {
      "customType": "regex",
      "description": "Track Python version in CI workflows",
      "managerFilePatterns": [
        "/\\.github/workflows/.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "PYTHON_VERSION:\\s*[\"'](?<currentValue>[0-9.]+)[\"']"
      ],
      "depNameTemplate": "python",
      "datasourceTemplate": "docker"
    }
  ]
}
